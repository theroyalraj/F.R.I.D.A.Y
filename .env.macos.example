# === macOS OpenClaw example env (copy to .env and fill secrets) ===

OPENCLAW_START_MODE=client
OPENCLAW_HOME=/Users/utkarshraj/openclaw

PC_AGENT_URL=http://localhost:3847
PC_AGENT_SECRET=your-secret-here

OPENCLAW_REDIS_URL=redis://127.0.0.1:6379

FRIDAY_TTS_VOICE=en-US-AvaMultilingualNeural
FRIDAY_CURSOR_NARRATION=true
FRIDAY_MACOS_SAY_VOICE=Samantha
FRIDAY_MACOS_SAY_RATE=200

CURSOR_TRANSCRIPTS_DIR=/Users/utkarshraj/.cursor/projects/Users-utkarshraj-openclaw/agent-transcripts

OPENCLAW_SYNC_RULE_TARGETS=/Users/utkarshraj/IdeaProjects/store-finance/jarvis/.cursor/rules

FRIDAY_AMBIENT=false
FRIDAY_EMAIL_WATCH=false
FRIDAY_CURSOR_SPEAK_REPLY=false
FRIDAY_CURSOR_SPEAK_THINKING=false
