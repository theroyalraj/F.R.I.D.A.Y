{
  "name": "openclaw",
  "private": true,
  "type": "module",
  "description": "Friday-style Alexa + N8N + Claude Code assistant",
  "workspaces": [
    "skill-gateway",
    "pc-agent"
  ],
  "scripts": {
    "start:gateway": "node skill-gateway/src/server.js",
    "start:agent": "node pc-agent/src/server.js",
    "dev:gateway": "npm run dev --prefix skill-gateway",
    "dev:agent": "npm run dev --prefix pc-agent",
    "tunnel:ngrok": "ngrok http 3848",
    "tunnel:friday": "ngrok http 3847",
    "tunnel:n8n": "ngrok http 5678",
    "heartbeat": "powershell -ExecutionPolicy Bypass -File scripts/openclaw-heartbeat.ps1",
    "start:all": "node scripts/start.mjs",
    "restart:local": "powershell -ExecutionPolicy Bypass -File scripts/restart-local.ps1",
    "restart:skip": "powershell -ExecutionPolicy Bypass -File scripts/restart-local.ps1 -SkipDocker -NoKill",
    "docker:postgres:up": "docker compose up -d openclaw-postgres",
    "test:notify": "node scripts/test-task-complete-notify.mjs",
    "test:mandatory-tts": "node scripts/test-mandatory-tts.mjs",
    "test:ambient-voices": "python scripts/test-ambient-voices.py",
    "test:ambient-checkin": "python scripts/test-ambient-checkin.py",
    "voice:daemon": "python scripts/friday-listen.py",
    "start:ambient": "python scripts/friday-ambient.py",
    "start:cursor-reply": "python scripts/cursor-reply-watch.py",
    "restart:watcher": "powershell -ExecutionPolicy Bypass -File scripts/restart-watcher.ps1",
    "start:email-watch": "python scripts/gmail-watch.py",
    "start:reminder-watch": "python scripts/friday-reminder-watch.py",
    "setup:alexa": "node scripts/setup-alexa-cookie.mjs",
    "play": "python skill-gateway/scripts/friday-play.py",
    "clear:locks": "python skill-gateway/scripts/clear_friday_locks.py",
    "install:all": "npm install",
    "test:friday-page": "node scripts/smoke-friday-page.mjs"
  }
}
