# Copy to .env and fill in. Never commit .env.

# Shared secret: same value for skill-gateway → N8N and N8N → pc-agent
N8N_WEBHOOK_SECRET=generate-a-long-random-string
PC_AGENT_SECRET=generate-another-long-random-string

# skill-gateway
PORT=3848
N8N_INTAKE_URL=http://127.0.0.1:5678/webhook/friday-intake
# Skip N8N: gateway calls pc-agent /task directly, then POSTs /internal/last-result (macOS app / simple setups).
# OPENCLAW_DIRECT_INTAKE=true
# PC_AGENT_URL=http://127.0.0.1:3847
# Override gateway → self for last-result when not on default port (optional)
# GATEWAY_INTERNAL_SELF_URL=http://127.0.0.1:3848
# Manual / curl queue (not Alexa): POST http://127.0.0.1:3848/openclaw/trigger + header X-Openclaw-Secret + JSON { "commandText": "open notepad", "userId": "…" }. See scripts/openclaw-trigger-curl.example.ps1
# Set false only for local Alexa test tools that skip signing
ALEXA_VERIFY_SIGNATURE=true

# Windows TTS — speaks task completion aloud through any audio device (BT headphones, speaker, etc.)
# Set default audio output in Windows Sound settings to choose the device.
# FRIDAY_WIN_TTS=true
# Windows TTS via edge-tts neural voice (requires: pip install edge-tts sounddevice soundfile)
# Plays audio directly to Echo Dot (or any WaveOut device) — falls back to system default
# FRIDAY_WIN_TTS_VOICE=en-GB-RyanNeural  # British English male / Jarvis-like (default)
#   Other voices: en-GB-ThomasNeural (deeper British male), en-IN-NeerjaExpressiveNeural (Hinglish female),
#                 en-IN-PrabhatNeural (Indian English male), hi-IN-SwaraNeural (Hindi), en-US-AriaNeural (US English)
# FRIDAY_WIN_TTS_DEVICE=Echo Dot  # device name substring; leave blank for system default
# FRIDAY_WIN_TTS_RATE=+0%         # edge-tts rate: +10% faster, -10% slower
# FRIDAY_WIN_TTS_PITCH=+0Hz       # pitch shift (e.g. +5Hz, -5Hz)
# FRIDAY_WIN_TTS_VOLUME=+0%       # volume (e.g. +10%)

# Optional: AI-generated notification summaries — Claude Haiku distils the task output into a
# punchy one-liner appended to the randomised phrase ("Friday — nailed it, Raj: <summary>").
# Requires Anthropic API key. Set NOTIFY_AI_SUMMARIES=false to use phrase-only mode.
# ANTHROPIC_API_KEY=sk-ant-...
# NOTIFY_AI_SUMMARIES=true
# NOTIFY_AI_MODEL=claude-haiku-4-5

# Optional: Alexa Proactive Events (device notification — "read my notifications"). See docs/setup.md § Alexa push notifications.
# LWA Security Profile (same app as skill) — client credentials with scope alexa::proactive_events enabled for Proactive Events.
# ALEXA_LWA_CLIENT_ID=
# ALEXA_LWA_CLIENT_SECRET=
# Skill API host (use api.eu.amazonalexa.com for EU skills)
# ALEXA_PROACTIVE_API_HOST=https://api.amazonalexa.com
# Use development proactive endpoint until skill is live + certified for MessageAlert (default: true)
# ALEXA_PROACTIVE_USE_DEVELOPMENT=true

# pc-agent
PC_AGENT_PORT=3847
# Listen address: default 0.0.0.0 (LAN + ngrok). Set 127.0.0.1 for loopback-only.
# PC_AGENT_BIND=127.0.0.1
# Friday /voice/* has no login — anyone who can reach the port can run tasks. Use firewall + ngrok auth or add your own auth before exposing.
# Working directory boundary for file/code tasks (Windows path)
PC_AGENT_WORKSPACE=D:\code
# Max ms for Claude CLI
CLAUDE_TIMEOUT_MS=180000
# Extra args before the prompt, space-separated (Claude Code CLI)
CLAUDE_CLI_ARGS=--print
# Model for tasks (Haiku = fast default). Omit to use haiku; set sonnet/opus for quality; inherit = CLI default only if you do not pass --model in CLAUDE_CLI_ARGS.
# CLAUDE_MODEL=haiku
# CLAUDE_MODEL=sonnet
# CLAUDE_MODEL=inherit
# When no claudeModel is sent (e.g. Alexa→N8N), auto-pick Haiku vs Sonnet from the prompt (coding/heavy → sonnet). Set false to use only CLAUDE_MODEL.
# CLAUDE_AUTO_MODEL=true
# Friday web UI (/friday): header “Claude model” dropdown → JSON field claudeModel on each command.

# Cursor agent narration: true = friday-speak on ack, status, and done summaries (see .cursor/rules). false = text only.
# FRIDAY_CURSOR_NARRATION=true
# Speak Composer subagent transcript prose via cursor-reply-watch.py (JSONL tail). Prose only; code stripped before TTS.
# FRIDAY_CURSOR_SPEAK_REPLY=true
# FRIDAY_CURSOR_SPEAK_SUBAGENT_REPLY=true
# FRIDAY_CURSOR_REPLY_VOICE=
# CURSOR_TRANSCRIPTS_DIR=C:\Users\YOURNAME\.cursor\projects\YOUR-PROJECT\agent-transcripts

# friday-speak.py — edge-tts neural voice (Python). Auto-enabled when script is present.
# pip install edge-tts sounddevice numpy  (ffmpeg on PATH)
# Windows: OpenClaw spawns friday-play.py with pythonw so no extra console flashes. Override if needed:
# FRIDAY_PYTHON_CHILD=C:\Path\To\pythonw.exe
# Set FRIDAY_SPEAK_PY=false to disable and fall back to Windows TTS.
# Voices: en-GB-RyanNeural (British male/Jarvis), en-US-AriaNeural, en-GB-SoniaNeural,
#         en-IN-NeerjaExpressiveNeural (Indian English female)
# Your first name (or how Friday should address you in speech + Alexa notify phrases). Default Raj.
FRIDAY_USER_NAME=Raj
# Your IANA timezone — used by ambient, check-in, and mode picker so time-of-day logic is correct
# even when TZ= is set to something else (e.g. America/New_York for Docker/n8n).
# Find yours: python -c "import zoneinfo; print(sorted(zoneinfo.available_timezones())[:5])"
# Common: Asia/Kolkata  Asia/Tokyo  America/New_York  Europe/London  America/Los_Angeles
FRIDAY_USER_TZ=Asia/Kolkata

# Main Cursor / coding assistant TTS. pick-session-voice.py sticks one voice per Composer chat (new chat = new pick).
# Without MAIN_RANDOM, new chats usually reuse FRIDAY_TTS_VOICE below (often Emma) unless the Hindi or Hinglish branch wins.
FRIDAY_TTS_VOICE=en-US-EmmaMultilingualNeural
FRIDAY_TTS_DEVICE=Echo Dot
# Never pick these in random pools or Hindi branch; if FRIDAY_TTS_VOICE is listed here, a pool fallback is used instead.
# Assistants (Claude Code, etc.): full policy in CLAUDE.md at repo root — do not suggest or set blocked voice ids anywhere.
FRIDAY_TTS_VOICE_BLOCK=en-AU-WilliamNeural,en-AU-WilliamMultilingualNeural,en-GB-RyanNeural,en-GB-ThomasNeural
# Per new Cursor chat: rotate through curated multilingual or expressive adults. Rare Ana roll. Omit or false to stay on FRIDAY_TTS_VOICE.
# FRIDAY_TTS_MAIN_RANDOM_VOICES=true
# Lock Cursor session picks to FRIDAY_TTS_VOICE only (no fifty-percent Hindi branch, no random pool).
# FRIDAY_TTS_SESSION_USE_ENV_VOICE_ONLY=true
# Ambient script: optional different voices so chimes are not the same timbre as main Jarvis
# FRIDAY_AMBIENT_TTS_VOICE=en-US-AriaNeural
# FRIDAY_AMBIENT_SUB_TTS_VOICE=en-GB-MaisieNeural
# Set true so ambient always uses FRIDAY_TTS_VOICE (skips Hinglish/Devanagari routing and overrides above).
# FRIDAY_AMBIENT_MAIN_VOICE_ONLY=true
# Default speed/pitch for most TTS (~1.075× + slightly bright; ambient main lines inherit .env)
FRIDAY_TTS_RATE=+7.5%
FRIDAY_TTS_PITCH=+2Hz
# First-contact TTS only (new chat welcome, pc-agent boot, friday-listen daemon start).
# Random rate/pitch each time (default). Set FRIDAY_TTS_JARVIS_RANDOM=false for fixed values below.
FRIDAY_TTS_JARVIS_RANDOM=true
# Optional integer bounds when random (percent / Hz) — defaults ~1.075× tier
# FRIDAY_TTS_JARVIS_RATE_MIN_PCT=3
# FRIDAY_TTS_JARVIS_RATE_MAX_PCT=12
# FRIDAY_TTS_JARVIS_PITCH_MIN_HZ=0
# FRIDAY_TTS_JARVIS_PITCH_MAX_HZ=10
# Used only when FRIDAY_TTS_JARVIS_RANDOM=false
FRIDAY_TTS_JARVIS_RATE=+7.5%
FRIDAY_TTS_JARVIS_PITCH=+2Hz
FRIDAY_TTS_VOLUME=+0%
# Hindi / Hinglish routing for friday-ambient + friday-listen (Edge short names):
# Roman Hinglish (Latin script) → Indian English neural — not your main Jarvis British voice.
# FRIDAY_TTS_HINGLISH_VOICE=en-IN-NeerjaExpressiveNeural
# Pure Devanagari → Hindi neural (overrides when text contains Hindi script).
# FRIDAY_TTS_DEVANAGARI_VOICE=hi-IN-SwaraNeural
# FRIDAY_SPEAK_PY=false

# Windows SAPI fallback when Edge cannot reach speech.platform.bing.com (VPN, firewall, offline).
# Use an installed voice name, e.g. Microsoft Zira Desktop (US female) or Microsoft David Desktop (US male).
# If FRIDAY_WIN_TTS_VOICE is empty, friday-speak uses a female gender hint (closer to default Emma).
# Optional: FRIDAY_WIN_TTS_GENDER=male or female
FRIDAY_WIN_TTS=true
FRIDAY_WIN_TTS_VOICE=Microsoft Zira Desktop
FRIDAY_WIN_TTS_RATE=+7.5%
FRIDAY_WIN_TTS_PITCH=+2Hz

# Windows: while Cursor is focused, friday-listen skips the mic and friday-ambient skips chimes.
# Other friday-speak calls defer by default (avoids doubling Cursor voice mode).
# Production exceptions always play: gateway startup + task-done, /voice/speak-async, FRIDAY_TTS_PRIORITY=1,
# and FRIDAY_TTS_BYPASS_CURSOR_DEFER=true. Test: npm run test:mandatory-tts
# Cursor agent rules set FRIDAY_TTS_BYPASS_CURSOR_DEFER on acks when narration is on.
# FRIDAY_DEFER_WHEN_CURSOR=true
# FRIDAY_DEFER_FOCUS_EXES=cursor
# FRIDAY_DEFER_SPEAK_WHEN_CURSOR=true

# Background music (friday-play.py): optional second output so TTS stays on headphones/speaker A and clips play on B.
# FRIDAY_MUSIC_DEVICE=Speakers
# If you have an Alexa cookie but hear no music on the PC: Alexa may be "winning" while playback stays on the Echo.
# Set true to always use yt-dlp + ffplay on Windows for FRIDAY_STARTUP_SONG / FRIDAY_DONE_SONG / launch init.
# FRIDAY_SONGS_PREFER_LOCAL_PC=true
# Voice or listen UI: natural phrases like "play Back in Black", "can you play the song …" call friday-play.py (yt-dlp + ffplay) via pc-agent before Claude — same stack as ambient clips. Needs yt-dlp, ffmpeg, ffplay on PATH.
# Shorter welcome / incidental clips (e.g. five to seven seconds): lower FRIDAY_PLAY_SECONDS from the default.
# FRIDAY_PLAY_SECONDS=6
# Background-level music so neural TTS / AI voice stays in front (ffplay 0–100; try twelve to twenty).
# FRIDAY_PLAY_VOLUME=12
# If music cuts off after only a second or two, ffprobe often lied about duration — raise this (default 30) or set FRIDAY_PLAY_EARLY_STOP_SEC=0
# FRIDAY_PLAY_MIN_TRUSTED_DURATION_SEC=30
# FRIDAY_PLAY_EARLY_STOP_SEC=2
#
# Startup / Alexa LaunchRequest: PC welcome TTS plays to completion first, then FRIDAY_STARTUP_SONG.
# FRIDAY_STARTUP_WELCOME_DELAY_MS=500   # ms after gateway listen (or launch) before spawning welcome
# FRIDAY_STARTUP_SONG_DELAY_MS=0        # extra ms after welcome exits before starting the song
#
# friday-play sets Redis friday:music:active (same URL as FRIDAY_AMBIENT_REDIS_URL). While active,
# friday-speak will not fade music unless FRIDAY_TTS_INTERRUPT_MUSIC=ui. friday-listen does not stop music from mic noise;
# spoken stop cuts music only after LISTEN_SONG_STOP_GRACE_SEC (default five seconds). Other voice commands still call stop when the hold ends.
# LISTEN_SONG_STOP_GRACE_SEC=5

# Friday web UI /voice/tts — server-side TTS for the browser voice UI (optional).
# Free offline neural: install Piper (https://github.com/rhasspy/piper/releases), download a voice .onnx + .onnx.json, then:
# PIPER_PATH=C:\path\piper\piper.exe
# PIPER_MODEL=C:\path\to\en_US-lessac-medium.onnx
# Paid cloud (off unless you opt in):
# FRIDAY_TTS_OPENAI=true
# OPENAI_API_KEY=sk-...
# FRIDAY_TTS_MODEL=gpt-4o-mini-tts

# Docker / n8n — cron in n8n uses GENERIC_TIMEZONE (e.g. Asia/Kolkata for nine and ten AM local).
GENERIC_TIMEZONE=America/New_York
TZ=America/New_York

# Gmail (scripts/gmail.py + pc-agent POST /automation/gmail-snapshot for n8n morning workflows)
# GMAIL_ADDRESS=you@gmail.com
# GMAIL_APP_PWD=xxxx xxxx xxxx xxxx
# Morning stack: Docker n8n cannot start Node on the host if pc-agent is down. Schedule Windows Task Scheduler
# a few minutes before nine AM, e.g. pwsh -ExecutionPolicy Bypass -File D:\code\openclaw\scripts\morning-start-openclaw.ps1
# Import n8n/workflows/morning-9am-email-kickoff.json and morning-10am-email-action-plan.json (requires compose profile whatsapp for Evolution).

# OpenClaw perception store — screen / camera captures, raw text, vision descriptions, pgvector embeddings.
# Start DB: docker compose up -d openclaw-postgres  (PostgreSQL on 127.0.0.1:5433 with pgvector; init SQL in docker/postgres/init/)
# OPENCLAW_POSTGRES_USER=openclaw
# OPENCLAW_POSTGRES_PASSWORD=openclaw
# OPENCLAW_POSTGRES_DB=openclaw
# pc-agent and scripts: connection string (must match user/password/db/port above)
# OPENCLAW_DATABASE_URL=postgresql://openclaw:openclaw@127.0.0.1:5433/openclaw
# Embedded DB (no Docker Postgres): perception + openclaw_settings. Vectors use in-process cosine search.
# OPENCLAW_SQLITE_PATH=/Users/you/.openclaw/openclaw.db
# macOS offline TTS fallback when Edge network fails (optional: say -v ?  list = say -v '?' )
# FRIDAY_MACOS_SAY_VOICE=Samantha
# Optional: mirror last capture summary to Redis key openclaw:perception:last (same Redis as n8n / ambient)
# OPENCLAW_REDIS_URL=redis://127.0.0.1:6379
# Vector column dimension in DB (change only before first init or after migrate). Default 1536 matches many OpenAI embeddings.
# OPENCLAW_EMBEDDING_DIM=1536
# Ingest API (requires PC_AGENT_SECRET): POST http://127.0.0.1:3847/perception/capture  Authorization: Bearer …
# narrate-screen.py: --store [--store-image] writes description (+ optional JPEG) after vision.
# Ambient timing from voice ("every N seconds") is stored in Postgres table openclaw_settings via GET/PUT
# http://127.0.0.1:3847/settings/ambient (Bearer PC_AGENT_SECRET) — friday-listen never writes .env for that.
# Existing DBs: run docker/postgres/init/02-openclaw-settings.sql once if the table is missing.


# Evolution API (optional profile whatsapp) — see docs/setup.md § WhatsApp
EVOLUTION_API_KEY=change-me
EVOLUTION_INSTANCE=default
# Optional: require this header on N8N webhook whatsapp-intake (set same in Evolution if supported)
# WHATSAPP_WEBHOOK_SECRET=another-long-random-string
# Digits-only allowlist — who may trigger commands (comma-separated)
# WHATSAPP_ALLOWED_NUMBERS=917870455443,917838481536,918904997949
# Every inbound reply is copied to ALL of these numbers (deduped). Omit to reply only to the sender.
# WHATSAPP_ALWAYS_REPLY_NUMBERS=917870455443,917838481536,918904997949
# Legacy single “always notify” target — not used by the stock workflow when WHATSAPP_ALWAYS_REPLY_NUMBERS is set
# WHATSAPP_NOTIFY_NUMBER=918904997949

# Public URL: use ngrok (see docs/setup.md §6). After `ngrok config add-authtoken ...`, run `npm run tunnel:ngrok`.
# Optional Cloudflare tunnel instead:
# CLOUDFLARE_TUNNEL_TOKEN=

# After each Alexa-originated task, friday-intake POSTs last-result with notify:true → Alexa Proactive MessageAlert (if LWA vars set). Optional: also enable for other callers via env:
# ALEXA_NOTIFY_ON_EACH_TASK_COMPLETION=true
# Test: npm run test:notify (needs gateway running). For a real device ping set NOTIFY_TEST_USER_ID=amzn1.ask.account.…
# The script asks after each run until you type "otherwise" / "stop asking" (or delete .openclaw-skip-notify-prompt). NOTIFY_TEST_NO_PROMPT=true skips that.

# Optional: AWS Lambda Python bridge (alexa-lambda-python/) — copy config.example.json → config.json; for Lambda use ngrok on N8N: npm run tunnel:n8n then set openclaw_intake_url to https://<host>.ngrok-free.app/webhook/friday-intake (do not commit config.json).

# Logging (see docs/debugging.md)
# NODE_ENV=production          # JSON logs, info level default
# LOG_LEVEL=debug              # trace | debug | info | warn | error | fatal
# OPENCLAW_LOG_DIR=logs        # also writes logs/skill-gateway.log and logs/pc-agent.log

# ── Jarvis ambient intelligence (scripts/friday-ambient.py) ─────────────────
# Fills silence with short jokes/facts; logs now-playing to Redis + SQLite.
# Python deps: pip install redis anthropic aiohttp py-now-playing
# FRIDAY_AMBIENT=true
# FRIDAY_AMBIENT_SILENCE_SEC=10
# FRIDAY_AMBIENT_MIN_SILENCE_SEC=6
# FRIDAY_AMBIENT_MAX_SILENCE_SEC=20
# FRIDAY_AMBIENT_TONE=mixed
# FRIDAY_AMBIENT_FUNNY_RATIO=0.6
# FRIDAY_AMBIENT_TRACK_MEDIA=true
# FRIDAY_AMBIENT_MUSIC_COMMENT_CHANCE=0.3
# Sub-agent check-in thread: time + wellness line; grabs Redis TTS lock so normal ambient waits
# FRIDAY_AMBIENT_CHECKIN_ENABLED=true
# FRIDAY_AMBIENT_CHECKIN_INTERVAL_SEC=3600
# FRIDAY_AMBIENT_CHECKIN_INITIAL_DELAY_SEC=120
# FRIDAY_USER_NAME=Raj
# FRIDAY_USER_AGE=
# FRIDAY_USER_CITY=Hyderabad
# FRIDAY_USER_TZ=Asia/Kolkata
# FRIDAY_USER_INTERESTS=technology,cricket,AI,startups,Bollywood
# FRIDAY_AMBIENT_REDIS_URL=redis://127.0.0.1:6379
# Local stack: npm run restart:local never starts or restarts Redis. If Redis is down: docker compose up -d redis
# FRIDAY_AMBIENT_DB_PATH=data/friday.db
# NEWS_API_KEY=
# CRICAPI_API_KEY=              # optional — live scores; with key + IPL calendar window, Hindi-IPL ambient/TTS only while an IPL match is live (match over → normal). No key = calendar window only.
# FRIDAY_IPL_ACTIVE=            # true = force IPL special mode always; false = force normal; omit = auto (live match if CricAPI key set, else calendar window)
# FRIDAY_IPL_WINDOW_START=03-22 # MM-DD local — IPL speech window start
# FRIDAY_IPL_WINDOW_END=05-31   # MM-DD local — IPL speech window end
# FRIDAY_IPL_HEADLINE_RATIO=0.5 # share of cricket headlines that are IPL-focused (when IPL speech on)
# FRIDAY_IPL_SPEECH_CACHE_SEC=21600   # legacy / unused (IPL live state uses CricAPI payload cache below)
# FRIDAY_IPL_CRICAPI_CACHE_SEC=600    # Redis TTL for CricAPI JSON blob
# FRIDAY_IPL_RSS_CACHE_SEC=3600       # general cricket RSS headline cache
# FRIDAY_IPL_IPL_RSS_CACHE_SEC=2400   # IPL Google News headline cache
# FRIDAY_IPL_SCORE_CACHE_SEC=180       # spoken score line cache
# FRIDAY_IPL_COMMENTARY_CACHE_SEC=45   # CricAPI match_info commentary snippet (per match id)
# FRIDAY_IPL_COMMENTARY_RSS_CACHE_SEC=180 # Google News fallback when API has no commentary
# FRIDAY_AMBIENT_LIVE_CACHE_SEC=600   # full live-data refresh interval (seconds)
# FRIDAY_AMBIENT_CRICKET_HINDI= # true/false; omit = auto when interests include cricket or IPL
# FRIDAY_AMBIENT_CRICKET_VOICE= # legacy: Devanagari TTS if FRIDAY_TTS_DEVANAGARI_VOICE unset; prefer FRIDAY_TTS_* above
# FRIDAY_AMBIENT_PREWARM_TTS=true
# FRIDAY_AMBIENT_CONTENT_QUEUE_SIZE=3
# FRIDAY_AMBIENT_SIMILARITY_SKIP=0.7   # skip TTS if Dice token overlap vs recent ambient exceeds this (0.35 to 0.99)
# FRIDAY_AMBIENT_SPOKEN_DEDUP_SEC=86400   # exact + semantic dedup vs spoken_log (default one day; minimum 3600)
# FRIDAY_AMBIENT_AI_LINE_CACHE_SEC=86400  # Redis TTL for cached Haiku ambient lines per topic (default one day)
# FRIDAY_AMBIENT_AI_MODEL=claude-haiku-4-5
# Uses ANTHROPIC_API_KEY when set (same as NOTIFY_AI).
# Ambient song moments: short iconic clip (~10s default). Tighten to ~5–7s with MAX=7 MIN=5 if you prefer.
# FRIDAY_AMBIENT_SONG_SECONDS=10
# FRIDAY_AMBIENT_SONG_SECONDS_MIN=8
# FRIDAY_AMBIENT_SONG_SECONDS_MAX=14
# After N successful ambient speech turns (Haiku lines, not song intros), force the featured-song workflow.
# Still skips when friday-play is already running and outside 07:00–23:59 local. Random FRIDAY_AMBIENT_SONG_CHANCE still applies too.
# FRIDAY_AMBIENT_SONG_AFTER_SPEECHES=3
# FRIDAY_AMBIENT_SONG_AFTER_SPEECHES=0   # disable; only random song chance

# ── Jarvis ambient intelligence (scripts/friday-ambient.py) ─────────────────
# Fills silence with short jokes/facts; logs now-playing to Redis + SQLite.
# Python deps: pip install redis anthropic aiohttp py-now-playing
# FRIDAY_AMBIENT=true
# FRIDAY_AMBIENT_SILENCE_SEC=10
# FRIDAY_AMBIENT_MIN_SILENCE_SEC=6
# FRIDAY_AMBIENT_MAX_SILENCE_SEC=20
# FRIDAY_AMBIENT_TONE=mixed
# FRIDAY_AMBIENT_FUNNY_RATIO=0.6
# FRIDAY_AMBIENT_TRACK_MEDIA=true
# FRIDAY_AMBIENT_MUSIC_COMMENT_CHANCE=0.3
# Sub-agent check-in thread: time + wellness line; grabs Redis TTS lock so normal ambient waits
# FRIDAY_AMBIENT_CHECKIN_ENABLED=true
# FRIDAY_AMBIENT_CHECKIN_INTERVAL_SEC=3600
# FRIDAY_AMBIENT_CHECKIN_INITIAL_DELAY_SEC=120
# FRIDAY_USER_NAME=Raj
# FRIDAY_USER_AGE=
# FRIDAY_USER_CITY=Hyderabad
# FRIDAY_USER_TZ=Asia/Kolkata
# FRIDAY_USER_INTERESTS=technology,cricket,AI,startups,Bollywood
# FRIDAY_AMBIENT_REDIS_URL=redis://127.0.0.1:6379
# Local stack: npm run restart:local never starts or restarts Redis. If Redis is down: docker compose up -d redis
# FRIDAY_AMBIENT_DB_PATH=data/friday.db
# NEWS_API_KEY=
# CRICAPI_API_KEY=
# FRIDAY_IPL_ACTIVE=
# FRIDAY_IPL_WINDOW_START=03-22
# FRIDAY_IPL_WINDOW_END=05-31
# FRIDAY_IPL_HEADLINE_RATIO=0.5
# FRIDAY_AMBIENT_CRICKET_HINDI=
# FRIDAY_AMBIENT_CRICKET_VOICE= # legacy Devanagari alias; prefer FRIDAY_TTS_DEVANAGARI_VOICE
# FRIDAY_AMBIENT_PREWARM_TTS=true
# FRIDAY_AMBIENT_CONTENT_QUEUE_SIZE=3
# FRIDAY_AMBIENT_SIMILARITY_SKIP=0.7   # skip TTS if Dice token overlap vs recent ambient exceeds this (0.35 to 0.99)
# FRIDAY_AMBIENT_SPOKEN_DEDUP_SEC=86400   # exact + semantic dedup vs spoken_log (default one day; minimum 3600)
# FRIDAY_AMBIENT_AI_LINE_CACHE_SEC=86400  # Redis TTL for cached Haiku ambient lines per topic (default one day)
# FRIDAY_AMBIENT_AI_MODEL=claude-haiku-4-5
# Uses ANTHROPIC_API_KEY when set (same as NOTIFY_AI).
