# Copy to .env and fill in. Never commit .env.

# Shared secret: same value for skill-gateway → N8N and N8N → pc-agent
N8N_WEBHOOK_SECRET=generate-a-long-random-string
PC_AGENT_SECRET=generate-another-long-random-string

# skill-gateway
PORT=3848
N8N_INTAKE_URL=http://127.0.0.1:5678/webhook/friday-intake
# Manual / curl queue (not Alexa): POST http://127.0.0.1:3848/openclaw/trigger + header X-Openclaw-Secret + JSON { "commandText": "open notepad", "userId": "…" }. See scripts/openclaw-trigger-curl.example.ps1
# Set false only for local Alexa test tools that skip signing
ALEXA_VERIFY_SIGNATURE=true

# Windows TTS — speaks task completion aloud through any audio device (BT headphones, speaker, etc.)
# Set default audio output in Windows Sound settings to choose the device.
# FRIDAY_WIN_TTS=true
# Windows TTS via edge-tts neural voice (requires: pip install edge-tts sounddevice soundfile)
# Plays audio directly to Echo Dot (or any WaveOut device) — falls back to system default
# FRIDAY_WIN_TTS_VOICE=en-GB-RyanNeural  # British English male / Jarvis-like (default)
#   Other voices: en-GB-ThomasNeural (deeper British male), en-IN-NeerjaExpressiveNeural (Hinglish female),
#                 en-IN-PrabhatNeural (Indian English male), hi-IN-SwaraNeural (Hindi), en-US-AriaNeural (US English)
# FRIDAY_WIN_TTS_DEVICE=Echo Dot  # device name substring; leave blank for system default
# FRIDAY_WIN_TTS_RATE=+0%         # edge-tts rate: +10% faster, -10% slower
# FRIDAY_WIN_TTS_PITCH=+0Hz       # pitch shift (e.g. +5Hz, -5Hz)
# FRIDAY_WIN_TTS_VOLUME=+0%       # volume (e.g. +10%)

# Optional: AI-generated notification summaries — Claude Haiku distils the task output into a
# punchy one-liner appended to the randomised phrase ("Friday — nailed it, Raj: <summary>").
# Requires Anthropic API key. Set NOTIFY_AI_SUMMARIES=false to use phrase-only mode.
# ANTHROPIC_API_KEY=sk-ant-...
# NOTIFY_AI_SUMMARIES=true
# NOTIFY_AI_MODEL=claude-haiku-4-5

# Optional: Alexa Proactive Events (device notification — "read my notifications"). See docs/setup.md § Alexa push notifications.
# LWA Security Profile (same app as skill) — client credentials with scope alexa::proactive_events enabled for Proactive Events.
# ALEXA_LWA_CLIENT_ID=
# ALEXA_LWA_CLIENT_SECRET=
# Skill API host (use api.eu.amazonalexa.com for EU skills)
# ALEXA_PROACTIVE_API_HOST=https://api.amazonalexa.com
# Use development proactive endpoint until skill is live + certified for MessageAlert (default: true)
# ALEXA_PROACTIVE_USE_DEVELOPMENT=true

# pc-agent
PC_AGENT_PORT=3847
# Listen address: default 0.0.0.0 (LAN + ngrok). Set 127.0.0.1 for loopback-only.
# PC_AGENT_BIND=127.0.0.1
# Friday /voice/* has no login — anyone who can reach the port can run tasks. Use firewall + ngrok auth or add your own auth before exposing.
# Working directory boundary for file/code tasks (Windows path)
PC_AGENT_WORKSPACE=D:\code
# Max ms for Claude CLI
CLAUDE_TIMEOUT_MS=180000
# Extra args before the prompt, space-separated (Claude Code CLI)
CLAUDE_CLI_ARGS=--print
# Model for tasks (Haiku = fast default). Omit to use haiku; set sonnet/opus for quality; inherit = CLI default only if you do not pass --model in CLAUDE_CLI_ARGS.
# CLAUDE_MODEL=haiku
# CLAUDE_MODEL=sonnet
# CLAUDE_MODEL=inherit
# When no claudeModel is sent (e.g. Alexa→N8N), auto-pick Haiku vs Sonnet from the prompt (coding/heavy → sonnet). Set false to use only CLAUDE_MODEL.
# CLAUDE_AUTO_MODEL=true
# Friday web UI (/friday): header “Claude model” dropdown → JSON field claudeModel on each command.

# friday-speak.py — edge-tts neural voice (Python). Auto-enabled when script is present.
# pip install edge-tts sounddevice numpy  (ffmpeg on PATH)
# Set FRIDAY_SPEAK_PY=false to disable and fall back to Windows TTS.
# Voices: en-GB-RyanNeural (British male/Jarvis), en-US-AriaNeural, en-GB-SoniaNeural,
#         en-IN-NeerjaExpressiveNeural (Indian English female)
FRIDAY_TTS_VOICE=en-GB-RyanNeural
FRIDAY_TTS_DEVICE=Echo Dot
# Default speed/pitch for most TTS (ambient, listen replies, skill-gateway, Cursor acks)
FRIDAY_TTS_RATE=+0%
FRIDAY_TTS_PITCH=+0Hz
# First-contact TTS only (new chat welcome, pc-agent boot, friday-listen daemon start).
# Random rate/pitch each time (default). Set FRIDAY_TTS_JARVIS_RANDOM=false for fixed values below.
FRIDAY_TTS_JARVIS_RANDOM=true
# Optional integer bounds when random (percent / Hz)
# FRIDAY_TTS_JARVIS_RATE_MIN_PCT=-10
# FRIDAY_TTS_JARVIS_RATE_MAX_PCT=12
# FRIDAY_TTS_JARVIS_PITCH_MIN_HZ=-6
# FRIDAY_TTS_JARVIS_PITCH_MAX_HZ=4
# Used only when FRIDAY_TTS_JARVIS_RANDOM=false
FRIDAY_TTS_JARVIS_RATE=-5%
FRIDAY_TTS_JARVIS_PITCH=-2Hz
FRIDAY_TTS_VOLUME=+0%
# FRIDAY_SPEAK_PY=false

# Windows TTS fallback (lower quality, offline):
FRIDAY_WIN_TTS=true
FRIDAY_WIN_TTS_VOICE=David
FRIDAY_WIN_TTS_RATE=1

# Windows: while Cursor is the focused app, friday-listen skips the mic and friday-ambient skips chimes (IDE dictation is not stolen). Cursor agent TTS via friday-speak is not blocked.
# FRIDAY_DEFER_WHEN_CURSOR=true
# FRIDAY_DEFER_FOCUS_EXES=cursor

# Friday web UI /voice/tts — server-side TTS for the browser voice UI (optional).
# Free offline neural: install Piper (https://github.com/rhasspy/piper/releases), download a voice .onnx + .onnx.json, then:
# PIPER_PATH=C:\path\piper\piper.exe
# PIPER_MODEL=C:\path\to\en_US-lessac-medium.onnx
# Paid cloud (off unless you opt in):
# FRIDAY_TTS_OPENAI=true
# OPENAI_API_KEY=sk-...
# FRIDAY_TTS_MODEL=gpt-4o-mini-tts

# Docker / n8n
GENERIC_TIMEZONE=America/New_York
TZ=America/New_York

# Evolution API (optional profile whatsapp) — see docs/setup.md § WhatsApp
EVOLUTION_API_KEY=change-me
EVOLUTION_INSTANCE=default
# Optional: require this header on N8N webhook whatsapp-intake (set same in Evolution if supported)
# WHATSAPP_WEBHOOK_SECRET=another-long-random-string

# Public URL: use ngrok (see docs/setup.md §6). After `ngrok config add-authtoken ...`, run `npm run tunnel:ngrok`.
# Optional Cloudflare tunnel instead:
# CLOUDFLARE_TUNNEL_TOKEN=

# After each Alexa-originated task, friday-intake POSTs last-result with notify:true → Alexa Proactive MessageAlert (if LWA vars set). Optional: also enable for other callers via env:
# ALEXA_NOTIFY_ON_EACH_TASK_COMPLETION=true
# Test: npm run test:notify (needs gateway running). For a real device ping set NOTIFY_TEST_USER_ID=amzn1.ask.account.…
# The script asks after each run until you type "otherwise" / "stop asking" (or delete .openclaw-skip-notify-prompt). NOTIFY_TEST_NO_PROMPT=true skips that.

# Optional: AWS Lambda Python bridge (alexa-lambda-python/) — copy config.example.json → config.json; for Lambda use ngrok on N8N: npm run tunnel:n8n then set openclaw_intake_url to https://<host>.ngrok-free.app/webhook/friday-intake (do not commit config.json).

# Logging (see docs/debugging.md)
# NODE_ENV=production          # JSON logs, info level default
# LOG_LEVEL=debug              # trace | debug | info | warn | error | fatal
# OPENCLAW_LOG_DIR=logs        # also writes logs/skill-gateway.log and logs/pc-agent.log

# ── Jarvis ambient intelligence (scripts/friday-ambient.py) ─────────────────
# Fills silence with short jokes/facts; logs now-playing to Redis + SQLite.
# Python deps: pip install redis anthropic aiohttp py-now-playing
# FRIDAY_AMBIENT=true
# FRIDAY_AMBIENT_SILENCE_SEC=10
# FRIDAY_AMBIENT_MIN_SILENCE_SEC=6
# FRIDAY_AMBIENT_MAX_SILENCE_SEC=20
# FRIDAY_AMBIENT_TONE=mixed
# FRIDAY_AMBIENT_FUNNY_RATIO=0.6
# FRIDAY_AMBIENT_TRACK_MEDIA=true
# FRIDAY_AMBIENT_MUSIC_COMMENT_CHANCE=0.3
# FRIDAY_USER_NAME=Raj
# FRIDAY_USER_AGE=
# FRIDAY_USER_CITY=Hyderabad
# FRIDAY_USER_INTERESTS=technology,cricket,AI,startups,Bollywood
# FRIDAY_AMBIENT_REDIS_URL=redis://127.0.0.1:6379
# FRIDAY_AMBIENT_DB_PATH=data/friday.db
# NEWS_API_KEY=
# FRIDAY_AMBIENT_PREWARM_TTS=true
# FRIDAY_AMBIENT_CONTENT_QUEUE_SIZE=3
# FRIDAY_AMBIENT_AI_MODEL=claude-haiku-4-5
# Uses ANTHROPIC_API_KEY when set (same as NOTIFY_AI).

